{erl_opts, [debug_info]}.

%% Plugins for Mix dependency support and linting
{plugins, [
    rebar_mix,
    {rebar3_lint, "3.2.5"}
]}.

{deps, [
    {mdns, "1.0.13"},
    {gproc, "0.9.1"}
]}.

%% Test configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.
{cover_opts, [verbose]}.

%% Common Test configuration
{ct_opts, [
    {sys_config, "config/sys.config"},
    {logdir, "_build/test/logs"},
    {ct_hooks, []},
    {auto_compile, true}
]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, []},
        %% Include test helpers in compilation path
        {extra_src_dirs, ["test/e2e/common"]},
        %% Ensure CT can find compiled helpers
        {ct_opts, [
            {sys_config, "config/sys.config"},
            {logdir, "_build/test/logs"},
            {auto_compile, true}
        ]}
    ]}
]}.
