{erl_opts, [debug_info]}.

%% Plugins for Mix dependency support (required for mdns which uses mix.exs)
{plugins, [rebar_mix]}.

%% Development plugins (optional)
{project_plugins, [{rebar3_lint, "3.2.5"}]}.

{deps, [
    {mdns, "1.0.13"},
    {gproc, "0.9.1"}
]}.

%% Test configuration
%% Only run EUnit tests for specific modules (not CT suites in test/e2e/)
{eunit_opts, [verbose]}.
{eunit_tests, [
    {module, gsmlg_epmd_cert_tests},
    {module, gsmlg_epmd_cookie_tests}
]}.
{cover_enabled, true}.
{cover_opts, [verbose]}.

%% Common Test configuration
%% E2E tests use auto_compile to compile helpers on demand
{ct_opts, [
    {sys_config, "config/sys.config"},
    {logdir, "_build/test/logs"},
    {ct_hooks, []},
    {auto_compile, true}
]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, []},
        %% CT opts for E2E tests - auto_compile handles test/e2e/common
        {ct_opts, [
            {sys_config, "config/sys.config"},
            {logdir, "_build/test/logs"},
            {auto_compile, true}
        ]}
    ]}
]}.
