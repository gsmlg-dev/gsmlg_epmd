{erl_opts, [debug_info]}.

%% Plugins for Mix dependency support and linting
{plugins, [
    rebar_mix,
    {rebar3_lint, "3.2.5"}
]}.

{deps, [
    {mdns, "1.0.13"},
    {gproc, "0.9.1"}
]}.

%% Test configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.
{cover_opts, [verbose]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]},
        {deps, []}
    ]}
]}.
