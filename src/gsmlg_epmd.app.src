{application, gsmlg_epmd,
 [{description, "GSMLG EPMD - Erlang distribution without EPMD, with TLS-based trust groups and mDNS discovery (fork of epmdless)"},
  {vsn, "0.4.0"},
  {registered, [gsmlg_epmd_sup, gsmlg_epmd_tls, gsmlg_epmd_cookie]},
  {mod, {gsmlg_epmd_app, []}},
  {applications,
   [kernel,
    stdlib,
    ssl,
    gproc,
    mdns
   ]},
  {env,[]},
  {modules, []},

  {licenses, ["Apache 2.0"]},
  {links, [{"GitHub", "https://github.com/gsmlg-dev/gsmlg_epmd"}]}
 ]}.
